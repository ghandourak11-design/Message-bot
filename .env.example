# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_token_here

# Your Discord application/client ID (found in Discord Developer Portal)
DISCORD_CLIENT_ID=your_discord_client_id_here

# The Discord channel ID where the bot sends logs
CHAT_CHANNEL_ID=your_discord_channel_id_here

# Minecraft server connection details
MINECRAFT_HOST=mc.donutsmp.net
MINECRAFT_PORT=25565
MINECRAFT_USERNAME=your_minecraft_username
MINECRAFT_PASSWORD=your_minecraft_password_if_needed
